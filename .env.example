# =============================================================================
# QDII 基金罗盘 — 环境变量模板
# 复制为 .env 后填入真实值。详见 README「配置说明：两套 Key 与最低要求」
# =============================================================================

# --- 必填：缺任一项服务无法启动 ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxx
SUPABASE_SECRET_KEY=sb_secret_xxxxxx

# --- BYOK（用户自带百炼 Key）---
# 登录用户在「模型设置」里填自己的 Key 时，服务端用此密钥加密存库。
# 生成：openssl rand -hex 32（64 位 hex）
# 上线后不可更改，否则已保存的用户 Key 无法解密。
# 留空：服务能启动，但用户无法在「模型设置」里保存 Key。
AI_KEY_SECRET=

# --- 平台 Key（可选）---
# 部署者自己的百炼 Key。用于：批量短长评、向量入库/检索、AI 热议等后台能力。
# 留空：基金浏览、用户 BYOK 聊天仍可用；向量检索与批量 AI 脚本不可用或降级。
# 注意：AI 投顾对话走用户自己的 Key，不走本项（v1.6 BYOK）。
DASHSCOPE_API_KEY=

# 接口地址：默认百炼官方；若 key 来自其它网关/中转平台，填该平台的 Base URL（不带末尾斜杠）
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 平台侧模型链：批量生成短长评、热议、embedding 等运营脚本使用（非用户聊天）
DASHSCOPE_CHAT_MODELS=qwen3.7-plus,qwen-plus-2025-07-28,qwen3-max,qwen3.5-plus-2026-02-15
# 单点兜底（少数未走模型链的直连调用）
DASHSCOPE_MODEL=qwen3.7-plus
DASHSCOPE_MODEL_FAST=qwen3.7-plus
DASHSCOPE_MODEL_STRONG=qwen3-max
DASHSCOPE_MODEL_STRONG_FALLBACK=qwen3.5-plus-2026-02-15
DASHSCOPE_ENABLE_THINKING=0
DASHSCOPE_THINKING_BUDGET=1200

# 向量嵌入（npm run data:embed 与聊天语义检索；需配 DASHSCOPE_API_KEY）
# DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3
# DASHSCOPE_EMBEDDING_DIM=1024

# --- 可选 ---
# AI Agent 最多轮次
AGENT_MAX_TURNS=12

# Tavily 联网搜索（留空则事件类问题降级）
TAVILY_API_KEY=

# 首页「更新时间」对齐的每日批次（Asia/Shanghai）
DATA_UPDATE_TIME=07:00

# 管理后台 /admin（留空则后台不可用）
ADMIN_PASSWORD=
