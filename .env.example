SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxx
SUPABASE_SECRET_KEY=sb_secret_xxxxxx

# DashScope（阿里云百炼）
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_MODEL_FAST=qwen-turbo
DASHSCOPE_MODEL_STRONG=qwen-max
DASHSCOPE_MODEL_STRONG_FALLBACK=qwen-plus
DASHSCOPE_ENABLE_THINKING=0
DASHSCOPE_THINKING_BUDGET=1200

# AI Agent
AGENT_MAX_TURNS=12
# Tavily Web Search（留空则事件类问题走降级话术）
TAVILY_API_KEY=

# 首页「更新时间」展示：按每日定时批次对齐（默认每天 07:00，Asia/Shanghai）
DATA_UPDATE_TIME=07:00
